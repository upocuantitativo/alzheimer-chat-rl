# ============================================================
# Configuración de razonadores LLM gratuitos
# ============================================================

# Groq (recomendado, gratis): https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# Alternativa más potente: llama-3.3-70b-versatile

# Ollama local (alternativa offline): https://ollama.com
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# HuggingFace Inference API (alternativa): https://huggingface.co/settings/tokens
# HF_TOKEN=
# HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# ============================================================
# Modo de ejecución
# ============================================================
# rules_only | llm_hybrid | llm_only
PATIENT_MODE=llm_hybrid

# Semilla por defecto para reproducibilidad
SEED=42
